---
import Layout from '../../layouts/Layout.astro';
import RecipeBook from '../../components/RecipeBook.jsx';
import { getRecipes } from '../../lib/notion.js';

const recipes = await getRecipes();
---

<Layout
  title="Recipes"
  description="Recipes by Sam Lauder."
>
  <div class="container">
    <header class="page-header">
      <h1>Recipes</h1>
      <p>A collection of things worth cooking.</p>
    </header>

    <RecipeBook recipes={recipes} client:load />
  </div>
</Layout>

<style>
  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--color-text-muted);
  }
</style>
