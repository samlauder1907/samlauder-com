---
import Layout from '../layouts/Layout.astro';

const heroImages = [
  { src: '/images/home/hero-1.jpg', alt: 'Architectural photography by Sam Lauder' },
  { src: '/images/home/hero-2.jpg', alt: 'Interior architecture photography' },
  { src: '/images/home/hero-3.jpg', alt: 'Commercial architecture photography' },
];

const featuredProjects = [
  {
    slug: 'urban-climb-adelaide',
    name: 'Urban Climb Adelaide',
    client: 'Urban Climb',
    cover: '/images/projects/urban-climb-adelaide/67440e3df224ab723da30e2e_UrbanClimb_Adelaide_01.jpg',
  },
  {
    slug: 'collingwood-yards',
    name: 'Collingwood Yards',
    client: 'Fieldwork Architects',
    cover: '/images/projects/collingwood-yards/61ade62f030213086162da64_CollingwoodYards011-Edit.jpeg',
  },
  {
    slug: 'collins-arch',
    name: 'Collins Arch',
    client: 'Woods Bagot + Shop Architects',
    cover: '/images/projects/collins-arch/cover.jpg',
  },
];
---

<Layout
  title="Sam Lauder Photography"
  description="Sam Lauder is a Melbourne-based architectural photographer specialising in architecture and the built environment."
>
  <section class="hero" aria-label="Featured work">
    <div class="hero-slides">
      {heroImages.map((img, i) => (
        <div class={`hero-slide slide-${i + 1}`}>
          <img src={img.src} alt={img.alt} loading={i === 0 ? 'eager' : 'lazy'} />
        </div>
      ))}
    </div>
    <div class="hero-overlay">
      <div class="container hero-content">
        <p class="hero-eyebrow">Architectural Photography</p>
        <h1>Capturing the built environment</h1>
        <p class="hero-body">Melbourne-based photographer working with architects, interior designers, and developers across Australia.</p>
        <div class="hero-actions">
          <a href="/portfolio" class="btn btn-primary">View Portfolio</a>
          <a href="/projects" class="btn btn-secondary">Browse Projects</a>
        </div>
      </div>
    </div>
  </section>

  <section class="featured-projects">
    <div class="container">
      <h2 class="section-heading">Selected Projects</h2>
      <div class="projects-grid">
        {featuredProjects.map(project => (
          <a href={`/projects/${project.slug}`} class="project-card">
            <div class="project-card-image">
              <img src={project.cover} alt={project.name} loading="lazy" />
            </div>
            <div class="project-card-info">
              <h3>{project.name}</h3>
              <p>{project.client}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="view-all">
        <a href="/projects" class="btn btn-outline">All Projects</a>
      </div>
    </div>
  </section>

  <section class="about-strip">
    <div class="container about-strip-inner">
      <div class="about-strip-text">
        <h2>Melbourne-based architectural photographer</h2>
        <p>
          I work with architects, interior designers, developers, and builders to document the built environment with clarity and craft. From large-scale commercial projects to residential interiors, I bring a considered eye to every commission.
        </p>
        <a href="/about" class="btn btn-outline">About Sam</a>
      </div>
      <div class="about-strip-image">
        <img src="/images/about/portrait.jpg" alt="Sam Lauder, architectural photographer" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="cta-strip">
    <div class="container">
      <h2>Ready to commission your next project?</h2>
      <p>Get in touch to discuss your photography needs.</p>
      <a href="/contact" class="btn btn-primary">Get in Touch</a>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    height: calc(100vh - var(--nav-height));
    min-height: 500px;
    overflow: hidden;
    background: #111;
  }

  .hero-slides {
    position: absolute;
    inset: 0;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
  }

  .hero-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .slide-1 { animation: heroFade 12s ease-in-out 0s infinite; }
  .slide-2 { animation: heroFade 12s ease-in-out 4s infinite; }
  .slide-3 { animation: heroFade 12s ease-in-out 8s infinite; }

  @keyframes heroFade {
    0%   { opacity: 0; }
    8%   { opacity: 1; }
    33%  { opacity: 1; }
    41%  { opacity: 0; }
    100% { opacity: 0; }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.55) 100%);
    display: flex;
    align-items: flex-end;
    padding-bottom: 5rem;
  }

  .hero-content {
    color: #fff;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    opacity: 0.8;
  }

  .hero-content h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1rem;
    max-width: 18ch;
  }

  .hero-body {
    font-size: 1rem;
    opacity: 0.85;
    max-width: 45ch;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: opacity 0.2s, background-color 0.2s, color 0.2s;
  }

  .btn-primary {
    background: #fff;
    color: #1a1a1a;
  }

  .btn-primary:hover {
    opacity: 0.85;
  }

  .btn-secondary {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.6);
  }

  .btn-secondary:hover {
    border-color: #fff;
    background: rgba(255,255,255,0.1);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-outline:hover {
    border-color: var(--color-text);
  }

  /* Featured Projects */
  .featured-projects {
    padding: 5rem 0;
  }

  .section-heading {
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 2.5rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .project-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .project-card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-border);
    margin-bottom: 0.75rem;
  }

  .project-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .project-card:hover .project-card-image img {
    transform: scale(1.04);
  }

  .project-card-info h3 {
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 0.2rem;
  }

  .project-card-info p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .view-all {
    text-align: center;
  }

  /* About strip */
  .about-strip {
    padding: 5rem 0;
    background: #f5f5f3;
  }

  .about-strip-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-strip-text h2 {
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 1.25rem;
    line-height: 1.25;
  }

  .about-strip-text p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .about-strip-image img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }

  /* CTA strip */
  .cta-strip {
    padding: 5rem 0;
    text-align: center;
  }

  .cta-strip h2 {
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }

  .cta-strip p {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero-overlay {
      padding-bottom: 3rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }

    .about-strip-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-strip-image {
      order: -1;
    }
  }
</style>
