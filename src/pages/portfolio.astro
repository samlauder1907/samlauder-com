  { src: '/images/portfolio/61ade62f030213086162da64_CollingwoodYards011-Edit.jpeg', alt: 'Collingwood Yards' },
  { src: '/images/portfolio/61b014a06477d1c2bf223cee_CollingwoodYards036-Edit.jpeg', alt: 'Collingwood Yards' },
  { src: '/images/portfolio/61ade683d574c4fa17b4ed10_CollingwoodYards072-Edit.jpg', alt: 'Collingwood Yards' },
