---
import Layout from '../layouts/Layout.astro';
import LightboxGallery from '../components/LightboxGallery.jsx';

const images = [
  { src: '/images/portfolio/portfolio-01.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/portfolio-02.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/portfolio-03.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/portfolio-04.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/portfolio-05.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/portfolio-06.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/portfolio-07.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/portfolio-08.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/portfolio-09.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/portfolio-10.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/portfolio-11.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/portfolio-12.jpg', alt: 'Architectural photography' },
];
---

<Layout
  title="Portfolio"
  description="Portfolio of architectural photography by Sam Lauder, Melbourne."
>
  <div class="container">
    <header class="page-header">
      <h1>Portfolio</h1>
      <p>A selection of architectural and interior photography commissions.</p>
    </header>

    <LightboxGallery images={images} client:load />
  </div>
</Layout>

<style>
  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--color-text-muted);
  }
</style>
