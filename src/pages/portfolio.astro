  { src: '/images/portfolio/64d1c210113d743623b18ead_08-web.jpg', alt: 'Canva Melbourne' },
  { src: '/images/portfolio/64d1c210802e32f615554dab_15-web.jpg', alt: 'Canva Melbourne' },
  { src: '/images/portfolio/627354ba1ae83754b68580a6_Detail.png', alt: 'Architectural photography' },
  { src: '/images/portfolio/627354ba209cb0ccbcf04178_Back1.png', alt: 'Architectural photography' },
  { src: '/images/portfolio/62735529d5f07a1eb39b6ce1_Front1.png', alt: 'Architectural photography' },
  { src: '/images/portfolio/61272edd46bf871ee0d6911c_China-2.jpg', alt: 'Architectural photography' },
