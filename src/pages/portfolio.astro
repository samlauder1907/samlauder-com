  { src: '/images/portfolio/6387e5d65e5c125683b9a78d_MBath_Vert.png', alt: 'Metricon Lumiere' },
  { src: '/images/portfolio/6387e5e01a4fa5ef04134c6f_Dining02.png', alt: 'Metricon Lumiere' },
  { src: '/images/portfolio/6387e5e68564603084ff6030_Bed01Chair_Vert.png', alt: 'Metricon Lumiere' },
  { src: '/images/portfolio/645b27affd36583328bee5c0_HeroAgain.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/645b27cad2b6d1b0fea0989e_KitchenHoirz.jpg', alt: 'Architectural photography' },
  { src: '/images/portfolio/646c08891af967cdce23f35c_exhibition-1.jpg', alt: 'Exhibition photography' },
  { src: '/images/portfolio/646c089eed0197176c8c7221_exhibition-2.jpg', alt: 'Exhibition photography' },
