---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.js';

const coverFallback = '/images/home/hero-1.jpg';

function projectCover(project) {
  if (project.images && project.images.length > 0) {
    return project.images[0];
  }
  return coverFallback;
}
---

<Layout
  title="Projects"
  description="Architectural photography projects by Sam Lauder, Melbourne."
>
  <div class="container">
    <header class="page-header">
      <h1>Projects</h1>
      <p>Selected commissions across commercial, civic, and residential architecture.</p>
    </header>

    <div class="projects-grid">
      {projects.map(project => (
        <a href={`/projects/${project.slug}`} class="project-card">
          <div class="project-card-image">
            <img
              src={projectCover(project)}
              alt={project.name}
              loading="lazy"
            />
          </div>
          <div class="project-card-info">
            <h2>{project.name}</h2>
            <p class="client">{project.client}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--color-text-muted);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .project-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .project-card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-border);
    margin-bottom: 0.75rem;
  }

  .project-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .project-card:hover .project-card-image img {
    transform: scale(1.04);
  }

  .project-card-info h2 {
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 0.2rem;
  }

  .client {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
