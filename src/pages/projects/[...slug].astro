---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.js';

export function getStaticPaths() {
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const allProjects = projects;
const currentIndex = allProjects.findIndex(p => p.slug === project.slug);
const prev = currentIndex > 0 ? allProjects[currentIndex - 1] : null;
const next = currentIndex < allProjects.length - 1 ? allProjects[currentIndex + 1] : null;
---

<Layout
  title={project.name}
  description={project.description || `${project.name} — architectural photography by Sam Lauder for ${project.client}.`}
>
  <div class="project-page">
    {project.images && project.images.length > 0 && (
      <div class="project-hero">
        <img
          src={project.images[0]}
          alt={project.name}
          loading="eager"
          class="hero-image"
        />
      </div>
    )}

    <div class="container">
      <div class="project-meta">
        <div class="project-meta-left">
          <h1>{project.name}</h1>
          <p class="project-client">{project.client}</p>
          {project.links && project.links.length > 0 && (
            <ul class="project-links">
              {project.links.map(link => (
                <li>
                  <a href={link.url} target="_blank" rel="noopener noreferrer">
                    {link.label} &rarr;
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
        {project.description && (
          <div class="project-description">
            <p>{project.description}</p>
          </div>
        )}
      </div>

      {project.images && project.images.length > 1 && (
        <div class="project-gallery">
          {project.images.slice(1).map((img, i) => (
            <figure class="gallery-item">
              <img
                src={img}
                alt={`${project.name} — image ${i + 2}`}
                loading="lazy"
              />
            </figure>
          ))}
        </div>
      )}

      {project.images && project.images.length === 0 && (
        <div class="no-images">
          <p>Images coming soon.</p>
        </div>
      )}

      <nav class="project-nav" aria-label="Project navigation">
        {prev ? (
          <a href={`/projects/${prev.slug}`} class="project-nav-link prev">
            <span class="nav-label">Previous</span>
            <span class="nav-project">{prev.name}</span>
          </a>
        ) : <div />}
        <a href="/projects" class="project-nav-all">All Projects</a>
        {next ? (
          <a href={`/projects/${next.slug}`} class="project-nav-link next">
            <span class="nav-label">Next</span>
            <span class="nav-project">{next.name}</span>
          </a>
        ) : <div />}
      </nav>
    </div>
  </div>
</Layout>

<style>
  .project-hero {
    width: 100%;
    max-height: 80vh;
    overflow: hidden;
    background: #111;
  }

  .hero-image {
    width: 100%;
    height: 80vh;
    object-fit: cover;
    display: block;
  }

  .project-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .project-meta h1 {
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }

  .project-client {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .project-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .project-links a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .project-links a:hover {
    color: var(--color-text);
  }

  .project-description p {
    line-height: 1.7;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .project-gallery {
    columns: 2;
    column-gap: 1rem;
    margin-bottom: 4rem;
  }

  .gallery-item {
    break-inside: avoid;
    margin: 0 0 1rem;
    background: var(--color-border);
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: auto;
  }

  .no-images {
    padding: 4rem 0;
    text-align: center;
    color: var(--color-text-muted);
  }

  .project-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: center;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    margin-bottom: 4rem;
  }

  .project-nav-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .project-nav-link.next {
    text-align: right;
  }

  .nav-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .nav-project {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .project-nav-link:hover .nav-project {
    text-decoration: underline;
  }

  .project-nav-all {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  .project-nav-all:hover {
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .project-meta {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .project-gallery {
      columns: 1;
    }

    .hero-image {
      height: 55vw;
      min-height: 250px;
    }

    .project-nav {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }

    .project-nav-all {
      grid-column: 1 / -1;
      order: -1;
      text-align: left;
    }
  }
</style>
