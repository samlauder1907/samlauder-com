---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { createSessionToken, isAuthenticated, COOKIE_NAME } from '../../lib/auth.js';
import { env } from 'cloudflare:workers';

if (await isAuthenticated(Astro.cookies, env)) {
  return Astro.redirect('/artchel');
}

let error = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const password = formData.get('password')?.toString() ?? '';

  if (password === env.ART_LOG_PASSWORD) {
    const token = await createSessionToken(env.ART_LOG_PASSWORD);
    Astro.cookies.set(COOKIE_NAME, token, {
      httpOnly: true,
      secure: true,
      sameSite: 'lax',
      maxAge: 60 * 60 * 24 * 30,
      path: '/',
    });
    return Astro.redirect('/artchel');
  }

  error = 'Incorrect password.';
}
---

<Layout title="Art Log" noindex={true}>
  <div class="container">
    <header class="page-header">
      <h1>Art Log</h1>
    </header>

    <div class="login-wrap">
      {error && <p class="error">{error}</p>}
      <form method="POST" class="login-form">
        <label for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          autocomplete="current-password"
          autofocus
          required
        />
        <button type="submit">Enter</button>
      </form>
    </div>
  </div>
</Layout>

<style>
  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .login-wrap {
    max-width: 320px;
  }

  .error {
    color: #b00;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .login-form label {
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .login-form input {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    font-size: 1rem;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color 0.15s;
  }

  .login-form input:focus {
    border-color: var(--color-text);
  }

  .login-form button {
    align-self: flex-start;
    padding: 0.6rem 1.5rem;
    background: var(--color-text);
    color: #fff;
    border: none;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .login-form button:hover {
    opacity: 0.8;
  }
</style>
