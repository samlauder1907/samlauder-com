---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { isAuthenticated } from '../../lib/auth.js';
import { env } from 'cloudflare:workers';

type Piece = {
  id: number;
  title: string;
  slug: string;
  status: string;
  cover_image_key: string | null;
  medium: string | null;
  notes: string | null;
  created_at: string;
};

type Photo = {
  id: number;
  image_key: string;
  caption: string | null;
  taken_at: string;
};

const { slug } = Astro.params;

const piece = await env.DB.prepare(
  `SELECT id, title, slug, status, cover_image_key, medium, notes, created_at
   FROM pieces WHERE slug = ?`
).bind(slug).first<Piece>();

if (!piece) {
  return new Response('Not found', { status: 404 });
}

const photos = (
  await env.DB.prepare(
    `SELECT id, image_key, caption, taken_at
     FROM progress_photos WHERE piece_id = ? ORDER BY taken_at ASC`
  ).bind(piece.id).all()
).results as Photo[];

const authenticated = await isAuthenticated(Astro.cookies, env);

function statusLabel(status: string) {
  if (status === 'in_progress') return 'In Progress';
  if (status === 'finished') return 'Finished';
  if (status === 'given_away') return 'Given Away';
  return status;
}

function formatDate(dateStr: string) {
  const d = dateStr.slice(0, 10);
  const [y, m, day] = d.split('-').map(Number);
  return new Date(y, m - 1, day).toLocaleDateString('en-AU', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title={piece.title}
  description={`${piece.title} — Art Log by Sam Lauder.`}
>
  <div class="container">
    <header class="page-header">
      <p class="back-link"><a href="/artchel">← Art Log</a></p>
      <div class="title-row">
        <h1>{piece.title}</h1>
        <span class:list={['status-badge', `status-badge--${piece.status}`]}>
          {statusLabel(piece.status)}
        </span>
      </div>
    </header>

    {piece.cover_image_key && (
      <div class="cover-wrap">
        <img
          src={`/artchel/images/${piece.cover_image_key}`}
          alt={piece.title}
          class="cover-image"
        />
      </div>
    )}

    {photos.length > 0 && (
      <section class="timeline">
        <h2>Progress</h2>
        <div class="timeline-grid">
          {photos.map(photo => (
            <div class="timeline-item">
              <div class="timeline-image">
                <img
                  src={`/artchel/images/${photo.image_key}`}
                  alt={photo.caption ?? piece.title}
                  loading="lazy"
                />
              </div>
              {(photo.caption || photo.taken_at) && (
                <div class="timeline-meta">
                  {photo.caption && <p class="timeline-caption">{photo.caption}</p>}
                  <p class="timeline-date">{formatDate(photo.taken_at)}</p>
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    {authenticated && (
      <section class="private-section">
        <h2>Notes</h2>
        {piece.medium && (
          <div class="private-field">
            <span class="field-label">Medium</span>
            <span class="field-value">{piece.medium}</span>
          </div>
        )}
        {piece.notes && (
          <div class="private-field private-field--notes">
            <span class="field-label">Notes</span>
            <p class="field-value notes-text">{piece.notes}</p>
          </div>
        )}
        {!piece.medium && !piece.notes && (
          <p class="no-notes">No notes recorded.</p>
        )}
        <a href={`/artchel/upload?piece=${piece.id}`} class="add-photo-link">
          Add progress photo →
        </a>
      </section>
    )}
  </div>
</Layout>

<style>
  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .back-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .status-badge {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .status-badge--given_away {
    border-style: dashed;
  }

  .cover-wrap {
    background: #f0f0f0;
    margin-bottom: 3rem;
    display: flex;
    justify-content: center;
  }

  .cover-image {
    display: block;
    max-width: 100%;
    max-height: 75vh;
    object-fit: contain;
  }

  .timeline {
    margin-bottom: 3rem;
  }

  .timeline h2 {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .timeline-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .timeline-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f0f0f0;
    margin-bottom: 0.5rem;
  }

  .timeline-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .timeline-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .timeline-caption {
    font-size: 0.85rem;
    color: var(--color-text);
  }

  .timeline-date {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .private-section {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
    margin-bottom: 4rem;
  }

  .private-section h2 {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .private-field {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 0.75rem;
    align-items: baseline;
  }

  .private-field--notes {
    align-items: flex-start;
  }

  .field-label {
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    min-width: 72px;
    flex-shrink: 0;
  }

  .field-value {
    font-size: 0.95rem;
  }

  .notes-text {
    white-space: pre-wrap;
    line-height: 1.6;
  }

  .no-notes {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .add-photo-link {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.1rem;
    transition: color 0.15s, border-color 0.15s;
  }

  .add-photo-link:hover {
    color: var(--color-text);
    border-color: var(--color-text);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .timeline-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .timeline-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
