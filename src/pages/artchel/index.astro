---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Artchel"
  description="Watercolours and gouache paintings by Sam Lauder."
  standalone={true}
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Marck+Script&family=Space+Grotesk:wght@400;500;600&display=swap" />

  <div class="page">
    <header class="page-header">
      <h1 class="page-title">Artchel</h1>
    </header>

    <p id="gallery-status" class="empty-state">Loading...</p>

    <div class="sort-controls" id="sort-controls" hidden aria-label="Sort gallery">
      <span class="sort-label">Sort</span>
      <button class="sort-btn sort-btn--active" data-sort="date">Date added</button>
      <button class="sort-btn" data-sort="medium">Medium</button>
      <button class="sort-btn" data-sort="stage">Stage</button>
    </div>

    <div id="gallery-grid" class="gallery-grid" hidden></div>

    <!-- Add a new piece -->
    <details class="upload-toggle">
      <summary><span class="upload-tab">+ add a piece</span></summary>
      <div class="upload-form-wrap">
        <form
          class="upload-form"
          method="POST"
          action="/api/artchel-upload"
          enctype="multipart/form-data"
        >
          <div class="field">
            <label for="title">Title</label>
            <input type="text" id="title" name="title" required autocomplete="off" />
          </div>
          <div class="field">
            <label for="medium">Medium</label>
            <select id="medium" name="medium" required>
              <option value="Watercolour">Watercolour</option>
              <option value="Gouache">Gouache</option>
              <option value="Mixed Media">Mixed Media</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="field">
            <label for="status">Status</label>
            <select id="status" name="status">
              <option value="In Progress">In Progress</option>
              <option value="Finished">Finished</option>
              <option value="Given Away">Given Away</option>
            </select>
          </div>
          <div class="field">
            <label for="cover_image">Cover image <span class="optional">(JPEG, PNG, or WebP)</span></label>
            <input type="file" id="cover_image" name="cover_image" accept="image/jpeg,image/png,image/webp" />
          </div>
          <button type="submit">Add piece</button>
        </form>
      </div>
    </details>

    <!-- Add a progress photo to an existing piece -->
    <details class="upload-toggle">
      <summary><span class="upload-tab">+ add a progress photo</span></summary>
      <div class="upload-form-wrap">
        <form class="upload-form" id="progress-form">
          <div class="field">
            <label for="progress-piece">Piece</label>
            <select id="progress-piece" name="piece_id" required>
              <option value="">Loading…</option>
            </select>
          </div>
          <div class="field">
            <label for="progress-image">New photo <span class="optional">(JPEG, PNG, or WebP)</span></label>
            <input type="file" id="progress-image" name="image" accept="image/jpeg,image/png,image/webp" required />
          </div>
          <div class="progress-form-footer">
            <button type="submit" id="progress-submit">Add photo</button>
            <span id="progress-feedback" class="inline-feedback" aria-live="polite"></span>
          </div>
        </form>
      </div>
    </details>
  </div>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" hidden aria-modal="true" role="dialog">
    <div class="lightbox-backdrop"></div>
    <div class="lightbox-panel">
      <button class="lightbox-close" aria-label="Close">&times;</button>

      <div class="lightbox-image-wrap">
        <button class="lb-photo-nav lb-photo-prev" id="lb-photo-prev" aria-label="Previous photo" hidden>&#8249;</button>
        <span class="lb-photo-counter" id="lb-photo-counter" hidden></span>
        <button class="lb-photo-nav lb-photo-next" id="lb-photo-next" aria-label="Next photo" hidden>&#8250;</button>
        <div class="lb-img-frame" id="lb-img-frame">
          <img id="lightbox-img" src="" alt="" />
        </div>
        <div id="lightbox-no-image" class="lightbox-no-image" hidden></div>
      </div>

      <div class="lightbox-meta">
        <h2 id="lightbox-title"></h2>
        <div id="lb-medium-badge" class="lb-medium-badge" hidden></div>

        <div class="lightbox-status-row">
          <select id="lightbox-status-select" class="status-select" aria-label="Status">
            <option value="In Progress">In Progress</option>
            <option value="Finished">Finished</option>
            <option value="Given Away">Given Away</option>
          </select>
          <span id="lightbox-status-feedback" class="inline-feedback" aria-live="polite"></span>
        </div>

        <!-- Given To: visible when status = Given Away -->
        <div class="lb-given-to-row" id="lb-given-to-row" hidden>
          <label for="lb-given-to">Given to</label>
          <div class="lb-given-to-input-row">
            <input type="text" id="lb-given-to" placeholder="Name…" autocomplete="off" />
            <button id="lb-given-to-save" class="lb-small-btn">Save</button>
          </div>
          <span id="lb-given-to-feedback" class="inline-feedback" aria-live="polite"></span>
        </div>

        <div class="lightbox-comment-section">
          <label for="lightbox-textarea">Notes</label>
          <textarea id="lightbox-textarea" rows="3" placeholder="Add a note…"></textarea>
          <button id="lightbox-save">Save note</button>
        </div>

        <div class="lb-progress-section">
          <label for="lb-progress-file">Add progress photo</label>
          <div class="lb-progress-row">
            <input type="file" id="lb-progress-file" accept="image/jpeg,image/png,image/webp" />
            <button id="lb-progress-btn" class="lb-small-btn">Upload</button>
          </div>
          <span id="lb-progress-feedback" class="inline-feedback" aria-live="polite"></span>
        </div>

        <button id="lb-delete" class="lb-delete-btn">Delete piece</button>
      </div>
    </div>
  </div>
</Layout>

<script>
  function esc(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function statusClass(s) {
    return s.toLowerCase().replace(/ /g, '_');
  }

  function renderCard(piece, idx) {
    const rot = (Math.random() * 6 - 3).toFixed(2);
    const image = piece.cover
      ? `<img src="${esc(piece.cover)}" alt="${esc(piece.title)}" loading="lazy" />`
      : `<div class="piece-card-placeholder"></div>`;
    const mediumHtml = piece.medium
      ? `<span class="piece-card-medium">${esc(piece.medium)}</span>`
      : '';
    return `
      <div class="piece-card" data-idx="${idx}" style="--rot:${rot}deg" role="button" tabindex="0" aria-label="Open ${esc(piece.title)}">
        <div class="piece-card-image">${image}</div>
        <div class="piece-card-info">
          <h2>${esc(piece.title)}</h2>
          ${mediumHtml}
          <span class="status-badge status-badge--${esc(statusClass(piece.status))}">${esc(piece.status)}</span>
        </div>
      </div>`;
  }

  // --- Sort ---
  let currentSort = 'date';

  function getSortedPieces() {
    const indexed = pieces.map((p, i) => ({ p, i }));
    switch (currentSort) {
      case 'date':
        return [...indexed].sort((a, b) => {
          const da = a.p.createdAt ? new Date(a.p.createdAt).getTime() : 0;
          const db = b.p.createdAt ? new Date(b.p.createdAt).getTime() : 0;
          return db - da;
        });
      case 'medium':
        return [...indexed].sort((a, b) =>
          (a.p.medium ?? '').localeCompare(b.p.medium ?? ''));
      case 'stage': {
        const order = { 'In Progress': 0, 'Finished': 1, 'Given Away': 2 };
        return [...indexed].sort((a, b) =>
          (order[a.p.status] ?? 3) - (order[b.p.status] ?? 3));
      }
      default:
        return indexed;
    }
  }

  function renderGallery() {
    gridEl.innerHTML = getSortedPieces().map(({ p, i }) => renderCard(p, i)).join('');
  }

  function updatePiecePicker() {
    if (pieces.length === 0) {
      progressPieceSelect.innerHTML = '<option value="">No pieces yet</option>';
    } else {
      progressPieceSelect.innerHTML =
        '<option value="">Select a piece…</option>' +
        pieces.map(p => `<option value="${esc(p.id)}">${esc(p.title)}</option>`).join('');
    }
  }

  // --- Lightbox state ---
  let pieces = [];
  let currentIdx = null;
  let currentPhotoIdx = 0;

  const lightbox           = document.getElementById('lightbox');
  const backdrop           = lightbox.querySelector('.lightbox-backdrop');
  const closeBtn           = lightbox.querySelector('.lightbox-close');
  const lbImgFrame         = document.getElementById('lb-img-frame');
  const lbImg              = document.getElementById('lightbox-img');
  const lbNoImg            = document.getElementById('lightbox-no-image');
  const lbTitle            = document.getElementById('lightbox-title');
  const lbMediumBadge      = document.getElementById('lb-medium-badge');
  const lbStatusSelect     = document.getElementById('lightbox-status-select');
  const lbStatusFeedback   = document.getElementById('lightbox-status-feedback');
  const lbGivenToRow       = document.getElementById('lb-given-to-row');
  const lbGivenToInput     = document.getElementById('lb-given-to');
  const lbGivenToSaveBtn   = document.getElementById('lb-given-to-save');
  const lbGivenToFeedback  = document.getElementById('lb-given-to-feedback');
  const lbTextarea         = document.getElementById('lightbox-textarea');
  const lbSave             = document.getElementById('lightbox-save');
  const lbProgressFile     = document.getElementById('lb-progress-file');
  const lbProgressBtn      = document.getElementById('lb-progress-btn');
  const lbProgressFeedback = document.getElementById('lb-progress-feedback');
  const lbDeleteBtn        = document.getElementById('lb-delete');
  const lbPhotoPrev        = document.getElementById('lb-photo-prev');
  const lbPhotoNext        = document.getElementById('lb-photo-next');
  const lbPhotoCounter     = document.getElementById('lb-photo-counter');

  function updateLightboxPhoto() {
    if (currentIdx === null) return;
    const url = pieces[currentIdx]?.photos?.[currentPhotoIdx]?.url ?? null;
    if (url) {
      lbImg.src = url;
      lbImg.alt = pieces[currentIdx].title;
      lbImgFrame.hidden = false;
      lbImg.hidden = false;
      lbNoImg.hidden = true;
    } else {
      lbImgFrame.hidden = true;
      lbImg.hidden = true;
      lbNoImg.hidden = false;
    }
  }

  function updatePhotoNav() {
    if (currentIdx === null) return;
    const count = pieces[currentIdx]?.photos?.length ?? 0;
    if (count <= 1) {
      lbPhotoPrev.hidden = true;
      lbPhotoNext.hidden = true;
      lbPhotoCounter.hidden = true;
    } else {
      lbPhotoPrev.hidden = false;
      lbPhotoNext.hidden = false;
      lbPhotoCounter.hidden = false;
      lbPhotoPrev.disabled = currentPhotoIdx === 0;
      lbPhotoNext.disabled = currentPhotoIdx === count - 1;
      lbPhotoCounter.textContent = `${currentPhotoIdx + 1} / ${count}`;
    }
  }

  function setGivenToVisibility(status) {
    lbGivenToRow.hidden = status !== 'Given Away';
  }

  function openLightbox(idx) {
    currentIdx = idx;
    const piece = pieces[idx];
    const photos = piece.photos ?? [];

    currentPhotoIdx = photos.length > 0 ? photos.length - 1 : 0;
    updateLightboxPhoto();
    updatePhotoNav();

    lbTitle.textContent = piece.title;

    if (piece.medium) {
      lbMediumBadge.textContent = piece.medium;
      lbMediumBadge.hidden = false;
    } else {
      lbMediumBadge.hidden = true;
    }

    lbStatusSelect.value = piece.status;
    lbStatusSelect.className = `status-select status-select--${statusClass(piece.status)}`;
    lbStatusFeedback.textContent = '';

    setGivenToVisibility(piece.status);
    lbGivenToInput.value = piece.givenTo ?? '';
    lbGivenToFeedback.textContent = '';

    lbTextarea.value = piece.comments ?? '';
    lbSave.textContent = 'Save note';
    lbSave.disabled = false;

    lbProgressFile.value = '';
    lbProgressFeedback.textContent = '';
    lbProgressBtn.disabled = false;

    lbDeleteBtn.textContent = 'Delete piece';
    lbDeleteBtn.disabled = false;

    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
    lbTextarea.focus();
  }

  function closeLightbox() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
    currentIdx = null;
    currentPhotoIdx = 0;
  }

  backdrop.addEventListener('click', closeLightbox);
  closeBtn.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

  lbPhotoPrev.addEventListener('click', () => {
    if (currentPhotoIdx > 0) { currentPhotoIdx--; updateLightboxPhoto(); updatePhotoNav(); }
  });
  lbPhotoNext.addEventListener('click', () => {
    const count = pieces[currentIdx]?.photos?.length ?? 0;
    if (currentPhotoIdx < count - 1) { currentPhotoIdx++; updateLightboxPhoto(); updatePhotoNav(); }
  });

  // --- Status change ---
  lbStatusSelect.addEventListener('change', async () => {
    if (currentIdx === null) return;
    const piece = pieces[currentIdx];
    const newStatus = lbStatusSelect.value;

    lbStatusSelect.disabled = true;
    lbStatusFeedback.textContent = 'Saving…';

    try {
      const res = await fetch('/api/artchel-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: piece.id, status: newStatus }),
      });

      if (!res.ok) {
        lbStatusFeedback.textContent = 'Error';
        lbStatusSelect.value = piece.status;
        lbStatusSelect.className = `status-select status-select--${statusClass(piece.status)}`;
        lbStatusSelect.disabled = false;
        return;
      }

      pieces[currentIdx].status = newStatus;
      lbStatusSelect.className = `status-select status-select--${statusClass(newStatus)}`;
      setGivenToVisibility(newStatus);

      // If switching TO Given Away, focus the given-to input for quick entry
      if (newStatus === 'Given Away' && !pieces[currentIdx].givenTo) {
        lbGivenToInput.focus();
      }

      const card = gridEl.querySelector(`[data-idx="${currentIdx}"]`);
      if (card) {
        const badge = card.querySelector('.status-badge');
        if (badge) {
          badge.textContent = newStatus;
          badge.className = `status-badge status-badge--${statusClass(newStatus)}`;
        }
      }

      lbStatusFeedback.textContent = 'Saved';
      lbStatusSelect.disabled = false;
      setTimeout(() => { lbStatusFeedback.textContent = ''; }, 1500);
    } catch {
      lbStatusFeedback.textContent = 'Error';
      lbStatusSelect.value = piece.status;
      lbStatusSelect.className = `status-select status-select--${statusClass(piece.status)}`;
      lbStatusSelect.disabled = false;
    }
  });

  // --- Given To save ---
  lbGivenToSaveBtn.addEventListener('click', async () => {
    if (currentIdx === null) return;
    const piece = pieces[currentIdx];
    const givenTo = lbGivenToInput.value;

    lbGivenToSaveBtn.disabled = true;
    lbGivenToFeedback.textContent = 'Saving…';

    try {
      const res = await fetch('/api/artchel-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: piece.id, status: piece.status, given_to: givenTo }),
      });

      if (!res.ok) {
        lbGivenToFeedback.textContent = 'Error';
        lbGivenToSaveBtn.disabled = false;
        return;
      }

      pieces[currentIdx].givenTo = givenTo.trim();
      lbGivenToFeedback.textContent = 'Saved';
      lbGivenToSaveBtn.disabled = false;
      setTimeout(() => { lbGivenToFeedback.textContent = ''; }, 1500);
    } catch {
      lbGivenToFeedback.textContent = 'Error';
      lbGivenToSaveBtn.disabled = false;
    }
  });

  // --- Note save ---
  lbSave.addEventListener('click', async () => {
    if (currentIdx === null) return;
    const piece = pieces[currentIdx];
    const comment = lbTextarea.value;

    lbSave.disabled = true;
    lbSave.textContent = 'Saving…';

    try {
      const res = await fetch('/api/artchel-comment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: piece.id, comment }),
      });

      if (!res.ok) {
        lbSave.textContent = 'Error — try again';
        lbSave.disabled = false;
        return;
      }

      pieces[currentIdx].comments = comment;
      lbSave.textContent = 'Saved';
      setTimeout(() => { lbSave.textContent = 'Save note'; lbSave.disabled = false; }, 1500);
    } catch {
      lbSave.textContent = 'Error — try again';
      lbSave.disabled = false;
    }
  });

  // --- In-lightbox progress photo upload ---
  lbProgressBtn.addEventListener('click', async () => {
    if (currentIdx === null) return;
    const piece = pieces[currentIdx];
    const file = lbProgressFile.files[0];
    if (!file) return;

    lbProgressBtn.disabled = true;
    lbProgressFeedback.textContent = 'Uploading…';

    const fd = new FormData();
    fd.append('piece_id', piece.id);
    fd.append('image', file);

    try {
      const res = await fetch('/api/artchel-progress', { method: 'POST', body: fd });
      const json = await res.json().catch(() => ({}));

      if (!res.ok) {
        lbProgressFeedback.textContent = json.error ?? 'Upload failed';
        lbProgressBtn.disabled = false;
        return;
      }

      const newPhoto = { url: json.url, date: new Date().toISOString() };
      pieces[currentIdx].photos = [...(piece.photos ?? []), newPhoto];
      pieces[currentIdx].cover = json.url;

      // Jump to the newly added photo
      currentPhotoIdx = pieces[currentIdx].photos.length - 1;
      updateLightboxPhoto();
      updatePhotoNav();

      // Update gallery card thumbnail
      const card = gridEl.querySelector(`[data-idx="${currentIdx}"]`);
      if (card) {
        const imgWrap = card.querySelector('.piece-card-image');
        if (imgWrap) {
          const existing = imgWrap.querySelector('img');
          if (existing) {
            existing.src = json.url;
          } else {
            imgWrap.innerHTML = `<img src="${esc(json.url)}" alt="${esc(piece.title)}" loading="lazy" />`;
          }
        }
      }

      lbProgressFeedback.textContent = 'Added!';
      lbProgressFile.value = '';
      lbProgressBtn.disabled = false;
      setTimeout(() => { lbProgressFeedback.textContent = ''; }, 2500);
    } catch {
      lbProgressFeedback.textContent = 'Upload failed';
      lbProgressBtn.disabled = false;
    }
  });

  // --- Delete piece ---
  lbDeleteBtn.addEventListener('click', async () => {
    if (currentIdx === null) return;
    const piece = pieces[currentIdx];

    if (!confirm(`Delete "${piece.title}"? This can't be undone from the site.`)) return;

    lbDeleteBtn.disabled = true;
    lbDeleteBtn.textContent = 'Deleting…';

    try {
      const res = await fetch('/api/artchel-delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: piece.id }),
      });

      if (!res.ok) {
        lbDeleteBtn.textContent = 'Error';
        lbDeleteBtn.disabled = false;
        return;
      }

      const deletedIdx = currentIdx;
      closeLightbox();

      pieces.splice(deletedIdx, 1);
      updatePiecePicker();

      if (pieces.length === 0) {
        gridEl.hidden = true;
        sortControls.hidden = true;
        statusEl.textContent = 'No pieces yet.';
        statusEl.hidden = false;
      } else {
        renderGallery();
      }
    } catch {
      lbDeleteBtn.textContent = 'Error';
      lbDeleteBtn.disabled = false;
    }
  });

  // --- Gallery ---
  const statusEl            = document.getElementById('gallery-status');
  const gridEl              = document.getElementById('gallery-grid');
  const sortControls        = document.getElementById('sort-controls');
  const progressPieceSelect = document.getElementById('progress-piece');
  const progressForm        = document.getElementById('progress-form');
  const progressSubmitBtn   = document.getElementById('progress-submit');
  const progressFeedback    = document.getElementById('progress-feedback');

  gridEl.addEventListener('click', e => {
    const card = e.target.closest('[data-idx]');
    if (card) openLightbox(parseInt(card.dataset.idx, 10));
  });
  gridEl.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') {
      const card = e.target.closest('[data-idx]');
      if (card) { e.preventDefault(); openLightbox(parseInt(card.dataset.idx, 10)); }
    }
  });

  sortControls.addEventListener('click', e => {
    const btn = e.target.closest('[data-sort]');
    if (!btn || btn.dataset.sort === currentSort) return;
    currentSort = btn.dataset.sort;
    sortControls.querySelectorAll('.sort-btn').forEach(b =>
      b.classList.toggle('sort-btn--active', b.dataset.sort === currentSort));
    renderGallery();
  });

  fetch('/api/artchel-list')
    .then(r => {
      if (!r.ok) throw new Error(`HTTP ${r.status}`);
      return r.json();
    })
    .then(data => {
      pieces = data;
      if (pieces.length === 0) {
        statusEl.textContent = 'No pieces yet.';
        updatePiecePicker();
      } else {
        statusEl.hidden = true;
        renderGallery();
        gridEl.hidden = false;
        sortControls.hidden = false;
        updatePiecePicker();
      }
    })
    .catch(() => {
      statusEl.textContent = 'Could not load pieces.';
    });

  // --- Standalone progress photo upload ---
  progressForm.addEventListener('submit', async e => {
    e.preventDefault();
    const pieceId = progressPieceSelect.value;
    if (!pieceId) return;
    const imageInput = progressForm.querySelector('input[type="file"]');
    const file = imageInput?.files?.[0];
    if (!file) return;

    progressSubmitBtn.disabled = true;
    progressFeedback.textContent = 'Uploading…';

    const fd = new FormData();
    fd.append('piece_id', pieceId);
    fd.append('image', file);

    try {
      const res = await fetch('/api/artchel-progress', { method: 'POST', body: fd });
      const json = await res.json().catch(() => ({}));

      if (!res.ok) {
        progressFeedback.textContent = json.error ?? 'Upload failed';
        progressSubmitBtn.disabled = false;
        return;
      }

      const idx = pieces.findIndex(p => p.id === pieceId);
      if (idx !== -1) {
        const newPhoto = { url: json.url, date: new Date().toISOString() };
        pieces[idx].photos = [...(pieces[idx].photos ?? []), newPhoto];
        pieces[idx].cover = json.url;

        const card = gridEl.querySelector(`[data-idx="${idx}"]`);
        if (card) {
          const imgWrap = card.querySelector('.piece-card-image');
          if (imgWrap) {
            const existing = imgWrap.querySelector('img');
            if (existing) {
              existing.src = json.url;
            } else {
              imgWrap.innerHTML = `<img src="${esc(json.url)}" alt="${esc(pieces[idx].title)}" loading="lazy" />`;
            }
          }
        }
      }

      progressFeedback.textContent = 'Added!';
      progressForm.reset();
      progressSubmitBtn.disabled = false;
      setTimeout(() => { progressFeedback.textContent = ''; }, 2500);
    } catch {
      progressFeedback.textContent = 'Upload failed';
      progressSubmitBtn.disabled = false;
    }
  });
</script>

<style>
  /* ── Page background ─────────────────────────── */
  :global(body) {
    background-color: #ddd8ce;
    background-image:
      repeating-linear-gradient(
        -45deg,
        transparent 0,
        transparent 3px,
        rgba(0, 0, 0, 0.018) 3px,
        rgba(0, 0, 0, 0.018) 4px
      ),
      repeating-linear-gradient(
        45deg,
        transparent 0,
        transparent 3px,
        rgba(0, 0, 0, 0.012) 3px,
        rgba(0, 0, 0, 0.012) 4px
      );
  }

  /* ── Page structure ───────────────────────────── */

  .page {
    padding: 3rem 2.5rem 5rem;
    max-width: 1300px;
    margin-inline: auto;
  }

  .page-header {
    padding-top: 1.5rem;
    margin-bottom: 3rem;
  }

  .page-title {
    font-family: 'Marck Script', cursive;
    font-size: clamp(3rem, 9vw, 6.5rem);
    color: #2c2420;
    transform: rotate(-2deg);
    display: inline-block;
    line-height: 1;
  }

  .empty-state {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    color: #7a6858;
    padding: 2rem 0;
  }

  /* ── Sort controls ────────────────────────────── */

  .sort-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
