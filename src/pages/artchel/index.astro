---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Art Log"
  description="Paintings and works in progress by Sam Lauder."
>
  <div class="container">
    <header class="page-header">
      <h1>Art Log</h1>
      <p>Paintings, works in progress, and finished pieces.</p>
    </header>

    <p id="gallery-status" class="empty-state">Loading...</p>
    <div id="gallery-grid" class="gallery-grid" hidden></div>

    <details class="upload-toggle">
      <summary>+ Add a piece</summary>
      <form
        class="upload-form"
        method="POST"
        action="/api/artchel-upload"
        enctype="multipart/form-data"
      >
        <div class="field">
          <label for="title">Title</label>
          <input type="text" id="title" name="title" required autocomplete="off" />
        </div>

        <div class="field">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="In Progress">In Progress</option>
            <option value="Finished">Finished</option>
            <option value="Given Away">Given Away</option>
          </select>
        </div>

        <div class="field">
          <label for="cover_image">Cover image <span class="optional">(JPEG, PNG, or WebP)</span></label>
          <input type="file" id="cover_image" name="cover_image" accept="image/jpeg,image/png,image/webp" />
        </div>

        <button type="submit">Add piece</button>
      </form>
    </details>
  </div>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" hidden aria-modal="true" role="dialog">
    <div class="lightbox-backdrop"></div>
    <div class="lightbox-panel">
      <button class="lightbox-close" aria-label="Close">&times;</button>
      <div class="lightbox-image-wrap">
        <img id="lightbox-img" src="" alt="" />
        <div id="lightbox-no-image" class="lightbox-no-image" hidden></div>
      </div>
      <div class="lightbox-meta">
        <h2 id="lightbox-title"></h2>
        <span id="lightbox-status" class="status-badge"></span>
        <div class="lightbox-comment-section">
          <label for="lightbox-textarea">Comment</label>
          <textarea id="lightbox-textarea" rows="4" placeholder="Add a comment…"></textarea>
          <button id="lightbox-save">Save comment</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  function esc(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function statusClass(status) {
    return status.toLowerCase().replace(/ /g, '_');
  }

  function renderCard(piece, idx) {
    const image = piece.cover
      ? `<img src="${esc(piece.cover)}" alt="${esc(piece.title)}" loading="lazy" />`
      : `<div class="piece-card-placeholder"></div>`;
    return `
      <div class="piece-card" data-idx="${idx}" role="button" tabindex="0" aria-label="Open ${esc(piece.title)}">
        <div class="piece-card-image">${image}</div>
        <div class="piece-card-info">
          <h2>${esc(piece.title)}</h2>
          <span class="status-badge status-badge--${esc(statusClass(piece.status))}">${esc(piece.status)}</span>
        </div>
      </div>`;
  }

  // --- Lightbox ---
  let pieces = [];
  let currentIdx = null;

  const lightbox   = document.getElementById('lightbox');
  const backdrop   = lightbox.querySelector('.lightbox-backdrop');
  const closeBtn   = lightbox.querySelector('.lightbox-close');
  const lbImg      = document.getElementById('lightbox-img');
  const lbNoImg    = document.getElementById('lightbox-no-image');
  const lbTitle    = document.getElementById('lightbox-title');
  const lbStatus   = document.getElementById('lightbox-status');
  const lbTextarea = document.getElementById('lightbox-textarea');
  const lbSave     = document.getElementById('lightbox-save');

  function openLightbox(idx) {
    currentIdx = idx;
    const piece = pieces[idx];

    if (piece.cover) {
      lbImg.src = piece.cover;
      lbImg.alt = piece.title;
      lbImg.hidden = false;
      lbNoImg.hidden = true;
    } else {
      lbImg.hidden = true;
      lbNoImg.hidden = false;
    }

    lbTitle.textContent = piece.title;
    lbStatus.textContent = piece.status;
    lbStatus.className = `status-badge status-badge--${statusClass(piece.status)}`;
    lbTextarea.value = piece.comments ?? '';
    lbSave.textContent = 'Save comment';
    lbSave.disabled = false;

    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
    lbTextarea.focus();
  }

  function closeLightbox() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
    currentIdx = null;
  }

  backdrop.addEventListener('click', closeLightbox);
  closeBtn.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

  lbSave.addEventListener('click', async () => {
    if (currentIdx === null) return;
    const piece = pieces[currentIdx];
    const comment = lbTextarea.value;

    lbSave.disabled = true;
    lbSave.textContent = 'Saving…';

    try {
      const res = await fetch('/api/artchel-comment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: piece.id, comment }),
      });

      if (!res.ok) {
        lbSave.textContent = 'Error — try again';
        lbSave.disabled = false;
        return;
      }

      pieces[currentIdx].comments = comment;
      lbSave.textContent = 'Saved';
      setTimeout(() => {
        lbSave.textContent = 'Save comment';
        lbSave.disabled = false;
      }, 1500);
    } catch {
      lbSave.textContent = 'Error — try again';
      lbSave.disabled = false;
    }
  });

  // --- Gallery ---
  const statusEl = document.getElementById('gallery-status');
  const gridEl   = document.getElementById('gallery-grid');

  gridEl.addEventListener('click', e => {
    const card = e.target.closest('[data-idx]');
    if (card) openLightbox(parseInt(card.dataset.idx, 10));
  });

  gridEl.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') {
      const card = e.target.closest('[data-idx]');
      if (card) { e.preventDefault(); openLightbox(parseInt(card.dataset.idx, 10)); }
    }
  });

  fetch('/api/artchel-list')
    .then(r => {
      if (!r.ok) throw new Error(`HTTP ${r.status}`);
      return r.json();
    })
    .then(data => {
      pieces = data;
      if (pieces.length === 0) {
        statusEl.textContent = 'No pieces yet.';
      } else {
        statusEl.hidden = true;
        gridEl.innerHTML = pieces.map(renderCard).join('');
        gridEl.hidden = false;
      }
    })
    .catch(() => {
      statusEl.textContent = 'Could not load pieces.';
    });
</script>

<style>
  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--color-text-muted);
  }

  .empty-state {
    color: var(--color-text-muted);
    padding: 2rem 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .piece-card {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .piece-card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f0f0f0;
    margin-bottom: 0.75rem;
    transition: opacity 0.15s, transform 0.2s;
  }

  .piece-card:hover .piece-card-image {
    opacity: 0.85;
    transform: scale(1.02);
  }

  .piece-card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .piece-card-placeholder {
    width: 100%;
    height: 100%;
  }

  .piece-card-info {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .piece-card-info h2 {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .status-badge {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .status-badge--given_away {
    border-style: dashed;
  }

  @media (max-width: 900px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Upload form */

  .upload-toggle {
    margin-top: 4rem;
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
    max-width: 520px;
  }

  .upload-toggle > summary {
    cursor: pointer;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    list-style: none;
    user-select: none;
  }

  .upload-toggle > summary::-webkit-details-marker {
    display: none;
  }

  .upload-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field label {
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .optional {
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.8rem;
    opacity: 0.8;
  }

  .field input[type='text'],
  .field input[type='file'],
  .field select {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    font-size: 0.95rem;
    font-family: var(--font-sans);
    color: var(--color-text);
    background: #fff;
    outline: none;
    transition: border-color 0.15s;
  }

  .field input:focus,
  .field select:focus {
    border-color: var(--color-text);
  }

  .field input[type='file'] {
    padding: 0.4rem 0.75rem;
    cursor: pointer;
  }

  .upload-form button {
    align-self: flex-start;
    padding: 0.65rem 1.75rem;
    background: var(--color-text);
    color: #fff;
    border: none;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .upload-form button:hover {
    opacity: 0.8;
  }

  /* Lightbox */

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
  }

  .lightbox-panel {
    position: relative;
    background: #fff;
    max-width: 1080px;
    width: 100%;
    max-height: calc(100vh - 3rem);
    overflow-y: auto;
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: auto 1fr;
  }

  .lightbox-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: none;
    border: none;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: 0.25rem 0.5rem;
    z-index: 1;
  }

  .lightbox-close:hover {
    color: var(--color-text);
  }

  .lightbox-image-wrap {
    grid-row: 1 / -1;
    background: #f0f0f0;
    min-height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .lightbox-no-image {
    width: 100%;
    height: 100%;
    min-height: 260px;
  }

  .lightbox-meta {
    padding: 2rem 2rem 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .lightbox-meta h2 {
    font-size: 1.1rem;
    font-weight: 500;
    padding-right: 2rem;
  }

  .lightbox-comment-section {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .lightbox-comment-section label {
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .lightbox-comment-section textarea {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    font-size: 0.9rem;
    font-family: var(--font-sans);
    color: var(--color-text);
    background: #fff;
    outline: none;
    resize: vertical;
    line-height: 1.5;
    transition: border-color 0.15s;
    flex: 1;
    min-height: 80px;
  }

  .lightbox-comment-section textarea:focus {
    border-color: var(--color-text);
  }

  #lightbox-save {
    align-self: flex-start;
    padding: 0.55rem 1.4rem;
    background: var(--color-text);
    color: #fff;
    border: none;
    font-size: 0.85rem;
    font-family: var(--font-sans);
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  #lightbox-save:hover:not(:disabled) {
    opacity: 0.8;
  }

  #lightbox-save:disabled {
    opacity: 0.5;
    cursor: default;
  }

  @media (max-width: 600px) {
    .lightbox-panel {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
    }

    .lightbox-image-wrap {
      grid-row: auto;
      min-height: 200px;
      max-height: 50vh;
    }

    .lightbox-meta {
      padding: 1.25rem;
    }
  }
</style>
