---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Art Log"
  description="Paintings and works in progress by Sam Lauder."
>
  <div class="container">
    <header class="page-header">
      <h1>Art Log</h1>
      <p>Paintings, works in progress, and finished pieces.</p>
    </header>

    <p id="gallery-status" class="empty-state">Loading...</p>
    <div id="gallery-grid" class="gallery-grid" hidden></div>

    <details class="upload-toggle">
      <summary>+ Add a piece</summary>
      <form
        class="upload-form"
        method="POST"
        action="/api/artchel-upload"
        enctype="multipart/form-data"
      >
        <div class="field">
          <label for="title">Title</label>
          <input type="text" id="title" name="title" required autocomplete="off" />
        </div>

        <div class="field">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="In Progress">In Progress</option>
            <option value="Finished">Finished</option>
            <option value="Given Away">Given Away</option>
          </select>
        </div>

        <div class="field">
          <label for="cover_image">Cover image <span class="optional">(JPEG, PNG, or WebP)</span></label>
          <input type="file" id="cover_image" name="cover_image" accept="image/jpeg,image/png,image/webp" />
        </div>

        <button type="submit">Add piece</button>
      </form>
    </details>
  </div>
</Layout>

<script>
  function esc(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function statusClass(status) {
    return status.toLowerCase().replace(/ /g, '_');
  }

  function renderCard(piece) {
    const image = piece.cover
      ? `<img src="${esc(piece.cover)}" alt="${esc(piece.title)}" loading="lazy" />`
      : `<div class="piece-card-placeholder"></div>`;
    return `
      <div class="piece-card">
        <div class="piece-card-image">${image}</div>
        <div class="piece-card-info">
          <h2>${esc(piece.title)}</h2>
          <span class="status-badge status-badge--${esc(statusClass(piece.status))}">${esc(piece.status)}</span>
        </div>
      </div>`;
  }

  const statusEl = document.getElementById('gallery-status');
  const gridEl = document.getElementById('gallery-grid');

  fetch('/api/artchel-list')
    .then(r => {
      if (!r.ok) throw new Error(`HTTP ${r.status}`);
      return r.json();
    })
    .then(pieces => {
      if (pieces.length === 0) {
        statusEl.textContent = 'No pieces yet.';
      } else {
        statusEl.hidden = true;
        gridEl.innerHTML = pieces.map(renderCard).join('');
        gridEl.hidden = false;
      }
    })
    .catch(() => {
      statusEl.textContent = 'Could not load pieces.';
    });
</script>

<style>
  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--color-text-muted);
  }

  .empty-state {
    color: var(--color-text-muted);
    padding: 2rem 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .piece-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .piece-card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f0f0f0;
    margin-bottom: 0.75rem;
  }

  .piece-card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .piece-card-placeholder {
    width: 100%;
    height: 100%;
  }

  .piece-card-info {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .piece-card-info h2 {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .status-badge {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .status-badge--given_away {
    border-style: dashed;
  }

  @media (max-width: 900px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }

  .upload-toggle {
    margin-top: 4rem;
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
    max-width: 520px;
  }

  .upload-toggle > summary {
    cursor: pointer;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    list-style: none;
    user-select: none;
  }

  .upload-toggle > summary::-webkit-details-marker {
    display: none;
  }

  .upload-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field label {
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .optional {
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.8rem;
    opacity: 0.8;
  }

  .field input[type='text'],
  .field input[type='file'],
  .field select {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    font-size: 0.95rem;
    font-family: var(--font-sans);
    color: var(--color-text);
    background: #fff;
    outline: none;
    transition: border-color 0.15s;
  }

  .field input:focus,
  .field select:focus {
    border-color: var(--color-text);
  }

  .field input[type='file'] {
    padding: 0.4rem 0.75rem;
    cursor: pointer;
  }

  .upload-form button {
    align-self: flex-start;
    padding: 0.65rem 1.75rem;
    background: var(--color-text);
    color: #fff;
    border: none;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .upload-form button:hover {
    opacity: 0.8;
  }
</style>
