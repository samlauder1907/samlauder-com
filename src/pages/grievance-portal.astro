---
import Layout from '../layouts/Layout.astro';

const FORMSPREE_ID = import.meta.env.FORMSPREE_GRIEVANCE_ID || 'GRIEVANCE_FORM_ID';

const dogImages = [
  { src: '/images/grievance/6844f8d48914891479811220_IMG_4939.jpeg', alt: 'Golden retriever' },
  { src: '/images/grievance/6844f8d2f462de4b269b00bc_IMG_0752.jpeg', alt: 'Golden retriever' },
  { src: '/images/grievance/6844f8d2224d04a9f08db126_SAM00089.JPG', alt: 'Golden retriever' },
];

const moods = [
  { value: 'abandoned', emoji: '🥺', label: 'Abandoned' },
  { value: 'angry', emoji: '😠', label: 'Angry' },
  { value: 'annoyed', emoji: '🙄', label: 'Annoyed' },
  { value: 'anxious', emoji: '😬', label: 'Anxious' },
  { value: 'apathetic', emoji: '😒', label: 'Apathetic' },
  { value: 'bored', emoji: '🥱', label: 'Bored' },
  { value: 'disappointed', emoji: '😞', label: 'Disappointed' },
  { value: 'frustrated', emoji: '😤', label: 'Frustrated' },
  { value: 'fine', emoji: '😊', label: "Actually, I'm fine" },
  { value: 'neutral', emoji: '😑', label: 'Neutral' },
  { value: 'overwhelmed', emoji: '🤯', label: 'Overwhelmed' },
  { value: 'remorseful', emoji: '😥', label: 'Remorseful' },
  { value: 'sad', emoji: '😔', label: 'Sad' },
  { value: 'stressed', emoji: '😰', label: 'Stressed' },
  { value: 'withdrawn', emoji: '😶‍🌫️', label: 'Withdrawn' },
];
---

<Layout
  title="Grievance Portal"
  description="Submit a grievance."
  noindex={true}
>
  <div class="container">
    <div class="grievance-layout">
      <div class="dog-strip" aria-hidden="true">
        {dogImages.map(img => (
          <img src={img.src} alt={img.alt} loading="eager" />
        ))}
      </div>

      <header class="grievance-header">
        <h1>Grievance Portal</h1>
        <p>
          Got a beef? File it here. All submissions are read. Not all will be acted upon. Some will be laughed at, privately, professionally.
        </p>
      </header>

      <form
        id="grievance-form"
        action={`https://formspree.io/f/${FORMSPREE_ID}`}
        method="POST"
        class="grievance-form"
      >
        <div class="form-field">
          <label for="grievant-email">Email <span class="optional">(optional — if you'd like a response)</span></label>
          <input
            type="email"
            id="grievant-email"
            name="email"
            autocomplete="email"
          />
        </div>

        <fieldset class="mood-fieldset">
          <legend>Current Mood</legend>
          <div class="mood-options">
            {moods.map(mood => (
              <label class="mood-option">
                <input type="checkbox" name="mood" value={mood.value} data-label={mood.label} />
                <span class="mood-emoji">{mood.emoji}</span>
                <span>{mood.label}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <input type="hidden" id="grievance-subject" name="subject" />

        <div class="form-field">
          <label for="grievance-detail">Details</label>
          <textarea
            id="grievance-detail"
            name="message"
            rows="7"
            required
            placeholder="Make your case. Be specific. Vague grievances are the most dismissible kind."
          ></textarea>
        </div>

        <div class="form-error" id="form-error" role="alert" aria-live="polite"></div>

        <button type="submit" class="btn-submit" id="submit-btn">Submit Grievance</button>
      </form>

      <div class="form-success" id="form-success" hidden>
        <div class="dog-strip" aria-hidden="true">
          {dogImages.map(img => (
            <img src={img.src} alt={img.alt} loading="lazy" />
          ))}
        </div>
        <h2>Grievance received.</h2>
        <p>Your complaint has been logged. It will be reviewed with all the seriousness it deserves.</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('grievance-form') as HTMLFormElement;
  const success = document.getElementById('form-success') as HTMLElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.textContent = '';

    // Auto-populate hidden subject from selected moods
    const checked = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="mood"]:checked'));
    const labels = checked.map(el => el.dataset.label ?? el.value);
    const subjectField = document.getElementById('grievance-subject') as HTMLInputElement;
    subjectField.value = labels.length > 0 ? `Feeling: ${labels.join(', ')}` : 'Grievance submission';

    submitBtn.disabled = true;
    submitBtn.textContent = 'Filing…';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.hidden = true;
        success.hidden = false;
      } else {
        const data = await res.json().catch(() => ({}));
        errorEl.textContent = data?.errors?.map((e: { message: string }) => e.message).join(', ')
          || 'Something went wrong. Please try again.';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Grievance';
      }
    } catch {
      errorEl.textContent = 'Could not submit. Please check your connection and try again.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Grievance';
    }
  });
</script>

<style>
  .grievance-layout {
    max-width: 640px;
    margin: 0 auto;
    padding: 4rem 0;
  }

  .dog-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .dog-strip img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }

  .grievance-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .grievance-header h1 {
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .grievance-header p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .grievance-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-field label {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .optional {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    opacity: 0.7;
  }

  .form-field input,
  .form-field textarea {
    font-family: inherit;
    font-size: 0.95rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text);
    appearance: none;
    outline: none;
    transition: border-color 0.2s;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--color-text);
  }

  .form-field textarea {
    resize: vertical;
  }

  .mood-fieldset {
    border: 1px solid var(--color-border);
    padding: 1.25rem 1.25rem 1rem;
  }

  .mood-fieldset legend {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    padding: 0 0.5rem;
  }

  .mood-options {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.6rem;
    margin-top: 0.75rem;
  }

  .mood-option {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    font-size: 0.875rem;
  }

  .mood-emoji {
    font-size: 1rem;
    line-height: 1;
  }

  .mood-option input[type="checkbox"] {
    width: 1rem;
    height: 1rem;
    accent-color: var(--color-text);
    cursor: pointer;
    flex-shrink: 0;
  }

  .form-error {
    font-size: 0.875rem;
    color: #c0392b;
    min-height: 1.25rem;
  }

  .btn-submit {
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 0.875rem 2rem;
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    cursor: pointer;
    align-self: flex-start;
    transition: opacity 0.2s;
  }

  .btn-submit:hover:not(:disabled) {
    opacity: 0.8;
  }

  .btn-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-success {
    padding: 1rem 0 3rem;
  }

  .form-success h2 {
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 0.75rem;
  }

  .form-success p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @media (max-width: 480px) {
    .mood-options {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
