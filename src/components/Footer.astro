---

<footer class="site-footer">
  <div class="container footer-inner">
    <a href="/" class="footer-logo">Sam Lauder Photography</a>
    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/privacy">Privacy Policy</a>
      <a href="mailto:SamLauderPhotography@gmail.com">Email</a>
    </nav>
    <p class="footer-copy">All content &copy; Sam Lauder 2024. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 4rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-logo {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .footer-logo:hover {
    text-decoration: none;
    opacity: 0.7;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer-links a:hover {
    color: var(--color-text);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    width: 100%;
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .footer-copy {
      width: auto;
    }
  }
</style>
